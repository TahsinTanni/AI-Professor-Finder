        "jsCode": "const raw = $input.item.json.candidates?.[0]?.content?.parts?.[0]?.text || \"\";\n\nfunction extract(label) {\n  const match = raw.match(new RegExp(label + \":\\\\s*(.+)\"));\n  return match ? match[1].trim() : \"N/A\";\n}\n\nconst scoreRaw = extract(\"RELEVANCE_SCORE\");\nconst score = parseInt(scoreRaw) || 0;\n\nconst prev = $('Code in JavaScript').item.json;\n\nreturn {\n  score,\n  country: prev.country,\n  name: prev.professorName,\n  university: prev.university,\n  relatablePaper: extract(\"MOST_RELATABLE_PAPER\"),\n  paperLink: prev.topPaperLink,\n  shouldEmail: extract(\"SHOULD_EMAIL\"),\n  fundingPotential: extract(\"FUNDING_POTENTIAL\"),\n  emailTips: extract(\"EMAIL_TALKING_POINTS\"),\n  fullAnalysis: raw\n};"
      },
